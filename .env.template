# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit your real credentials.

# GitHub credentials (used by scripts/setup.sh and scripts/git_sync.sh)
GITHUB_USERNAME=
GITHUB_TOKEN=
GITHUB_REPO=
BRANCH=main

# Local Python interpreter (set by scripts/setup.sh; can be left blank)
PYTHON_BIN=

# TensorBoard / Jupyter
JUPYTER_PORT=8888

# Path to GCP service account JSON (for the gen_2d / train_eval GCS backends).
# Leave unset if you do not use GCP.
GOOGLE_APPLICATION_CREDENTIALS=
